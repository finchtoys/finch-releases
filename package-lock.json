{
  "name": "finch-releases",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "finch-releases",
      "version": "0.0.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@finch.app/extensions": {
      "resolved": "packages/extensions",
      "link": true
    },
    "node_modules/@finch.app/skills": {
      "resolved": "packages/skills",
      "link": true
    },
    "node_modules/@finch/extension-api": {
      "resolved": "packages/extension-api",
      "link": true
    },
    "packages/extension-api": {
      "name": "@finch/extension-api",
      "version": "0.1.0"
    },
    "packages/extensions": {
      "name": "@finch.app/extensions",
      "version": "0.1.4",
      "license": "MIT",
      "bin": {
        "finch-extensions": "bin/extensions.mjs"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skills": {
      "name": "@finch.app/skills",
      "version": "0.1.7",
      "license": "MIT",
      "bin": {
        "finch-skills": "bin/skills.mjs"
      },
      "engines": {
        "node": ">=18"
      }
    }
  }
}
