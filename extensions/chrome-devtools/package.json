{
  "name": "finch-chrome-devtools",
  "version": "1.5.0",
  "description": "Chrome DevTools MCP extension for Finch.",
  "author": {
    "name": "Finch Team",
    "url": "https://finchwork.app"
  },
  "homepage": "https://finchwork.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finchtoys/finch-releases.git",
    "directory": "extensions/chrome-devtools"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "finch": {
    "manifestVersion": 1,
    "id": "chrome-devtools",
    "name": "Chrome DevTools",
    "description": "Connect Chrome DevTools through MCP and let Finch inspect, debug, and operate Chrome pages.",
    "toolMeta": {
      "name": "Chrome DevTools"
    },
    "systemPrompt": "When the user needs webpage debugging, DOM inspection, console error analysis, network request analysis, browser screenshots, page performance analysis, or Chrome tab operation, use Chrome DevTools MCP tools through the MCP Client. Call ToolSearch with source:\"mcp\" before using mcp__chrome_devtools__* tools.",
    "promptGuides": [
      {
        "id": "debug-page",
        "title": "Debug current page",
        "description": "Inspect console and network issues in Chrome.",
        "prompt": "/chrome-devtools Use Chrome DevTools to inspect the current page, summarize console errors and failed network requests, then suggest fixes."
      },
      {
        "id": "analyze-performance",
        "title": "Analyze performance",
        "description": "Look for page performance bottlenecks.",
        "prompt": "/chrome-devtools Use Chrome DevTools to analyze this page's performance and tell me the biggest bottlenecks."
      }
    ],
    "main": "dist/index.js",
    "activationEvents": [
      "onStartup"
    ],
    "extensionType": "official",
    "categories": [
      "developer"
    ],
    "privacyPolicyUrl": "https://finchwork.app/privacy",
    "termsOfServiceUrl": "https://finchwork.app/terms",
    "requires": {
      "capabilities": [
        "mcp.client"
      ]
    },
    "contributes": {
      "skills": true,
      "mcpServers": [
        {
          "name": "chrome-devtools",
          "command": "npx",
          "args": [
            "-y",
            "chrome-devtools-mcp@1.5.0"
          ],
          "description": "Chrome DevTools MCP server for browser debugging, page inspection, network analysis, screenshots, and browser automation.",
          "toolMeta": {
            "titles": {
              "click": "Click element",
              "close_page": "Close page",
              "drag": "Drag element",
              "emulate": "Emulate browser features",
              "evaluate_script": "Evaluate script",
              "fill": "Fill field",
              "fill_form": "Fill form",
              "list_console_messages": "List console messages",
              "list_network_requests": "List network requests",
              "list_pages": "List Chrome pages",
              "new_page": "Open new page",
              "select_page": "Select Chrome page",
              "take_screenshot": "Take screenshot"
            }
          },
          "toolDisplay": {
            "tools": {
              "evaluate_script": {
                "inline": {
                  "mode": "join",
                  "fields": [
                    {
                      "path": "function",
                      "format": "truncate",
                      "maxLength": 80
                    }
                  ],
                  "template": "{function}"
                }
              },
              "click": {
                "inline": {
                  "mode": "join",
                  "fields": [
                    {
                      "path": "uid",
                      "maxLength": 40
                    }
                  ],
                  "template": "uid:{uid}"
                }
              },
              "fill": {
                "inline": {
                  "mode": "join",
                  "fields": [
                    {
                      "path": "uid",
                      "maxLength": 32
                    },
                    {
                      "path": "value",
                      "format": "truncate",
                      "maxLength": 40
                    }
                  ],
                  "template": "uid:{uid} value:{value}"
                }
              },
              "select_page": {
                "inline": {
                  "mode": "join",
                  "fields": [
                    {
                      "path": "pageIdx",
                      "maxLength": 12
                    }
                  ],
                  "template": "page:{pageIdx}"
                }
              },
              "new_page": {
                "inline": {
                  "mode": "join",
                  "fields": [
                    {
                      "path": "url",
                      "format": "truncate",
                      "maxLength": 80
                    }
                  ],
                  "template": "{url}"
                }
              }
            }
          }
        }
      ]
    },
    "permissions": {
      "filesystem": "none",
      "network": true,
      "shell": true
    }
  },
  "devDependencies": {
    "@finchtoys/minitool-api": "^0.1.16",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/",
    "i18n/",
    "skills/",
    "icon.png",
    "README.md",
    "README.zh-CN.md"
  ]
}
