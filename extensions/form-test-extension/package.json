{
  "name": "form-test-extension",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "finch": {
    "manifestVersion": 1,
    "id": "form-test",
    "name": "Form Test",
    "description": "测试 Finch 扩展自定义提问 UI 功能（exec.ui.requestForm）",
    "systemPrompt": "当用户需要测试表单、填写配置或登录时，优先使用本扩展的工具。",
    "promptGuides": [
      {
        "id": "try-all-fields",
        "title": "测试全部表单字段",
        "description": "展示所有字段类型的表单",
        "prompt": "我想测试一下表单的所有字段类型"
      },
      {
        "id": "try-login",
        "title": "测试登录表单",
        "description": "模拟登录场景",
        "prompt": "帮我测试一下登录表单"
      }
    ],
    "main": "dist/index.js",
    "activationEvents": ["onStartup"],
    "contributes": {
      "tools": true,
      "composerActions": [
        {
          "id": "form-quick",
          "icon": "ClipboardList",
          "tooltip": "快速表单测试"
        }
      ]
    },
    "permissions": {
      "filesystem": "none",
      "network": false,
      "shell": false
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
