{
  "name": "@finch.app/plan-mode",
  "version": "0.1.4",
  "description": "Planning mode for Finch conversations.",
  "author": {
    "name": "Finch Team",
    "url": "https://finchwork.app"
  },
  "homepage": "https://finchwork.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finchtoys/finch-releases.git",
    "directory": "extensions/plan-mode"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "i18n/",
    "icon.png",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "finch": {
    "manifestVersion": 1,
    "id": "plan-mode",
    "name": "plan",
    "description": "Planning mode for Finch conversations.",
    "systemPrompt": "When the user wants to plan before acting, or break down a task before execution, suggest using Plan Mode.",
    "main": "dist/index.js",
    "activationEvents": [
      "onStartup"
    ],
    "extensionType": "official",
    "categories": [
      "productivity"
    ],
    "privacyPolicyUrl": "https://finchwork.app/privacy",
    "termsOfServiceUrl": "https://finchwork.app/terms",
    "contributes": {
      "composerActions": [
        {
          "id": "plan-mode",
          "icon": "clipboard",
          "tooltip": "Plan Mode"
        }
      ]
    },
    "permissions": {
      "filesystem": "none",
      "network": false,
      "shell": false
    }
  },
  "devDependencies": {
    "@finch.app/minitool-api": "^0.1.16",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
