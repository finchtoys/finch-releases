{
  "name": "@finch.app/plan",
  "version": "0.1.0",
  "description": "Toggle planning mode from the Finch Composer toolbar.",
  "author": {
    "name": "Finch Team",
    "url": "https://finchwork.app"
  },
  "homepage": "https://finchwork.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finchtoys/finch-releases.git",
    "directory": "extensions/plan-mode"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "finch": {
    "manifestVersion": 1,
    "id": "plan-mode",
    "name": "plan",
    "description": "Add a one-tap planning mode button that injects planning-only reminders into each turn.",
    "systemPrompt": "当用户需要先规划、拆解方案、暂不执行时，可使用 Plan Mode 扩展切换到计划模式。",
    "main": "dist/index.js",
    "activationEvents": [
      "onStartup"
    ],
    "extensionType": "official",
    "categories": [
      "productivity"
    ],
    "privacyPolicyUrl": "https://finchwork.app/privacy",
    "termsOfServiceUrl": "https://finchwork.app/terms",
    "contributes": {
      "composerActions": [
        {
          "id": "plan-mode",
          "icon": "clipboard",
          "tooltip": "做计划"
        }
      ]
    },
    "permissions": {
      "filesystem": "none",
      "network": false,
      "shell": false
    }
  },
  "devDependencies": {
    "@finch.app/minitool-api": "^0.1.13",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
